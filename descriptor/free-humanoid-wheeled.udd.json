      { "name": "tower_stand",      "mass_kg": 4.500, "inertia": [1.5e-1, 1.5e-1, 2.0e-2, 0, 0, 0], "geometry_ref": { "type": "mesh_hash", "hash": "free_humanoid_wheeled_tower_stand_v0" }, "_metadata": { "comment": "Rigid 6061-T6 aluminum tower stand. Mounts upper body pelvis at 0.55 m above ground via prismatic torso lift. Includes prismatic torso lift +/-150 mm via belt-driven linear stage (Phase 1 spec: Igus DryLin SHTS-15-300 carbon-rail stage + NEMA-23 stepper + GT2 belt + IGUS leadscrew alternative). Lidar mount at top (1.0 m): Livox MID-360 mount fixture. GPS mount at top: u-blox L1/L2 RTK helical antenna. Corpus citation: toyota-hsr (telescoping torso). Vendor: Igus (rail), StepperOnline / OMC (motor)." } },

      { "name": "lidar_top",        "mass_kg": 0.265, "inertia": [3.0e-4, 3.0e-4, 3.0e-4, 0, 0, 0], "geometry_ref": { "type": "mesh_hash", "hash": "free_humanoid_wheeled_lidar_mid360_v0" }, "_metadata": { "comment": "Tower-top lidar. Phase 1 spec: Livox MID-360 360-deg non-repetitive scan lidar, 40 m range at 80% reflectivity, ~1.5 deg vertical FoV centered ~+/-7 deg, 20 Hz frame rate, IP67. Used for dock approach, obstacle avoidance, curbedge detection. Vendor: Livox (DJI affiliate). Corpus citation: dlr-justin, pr2 (post-2012 lidar additions), hyundai-boston-dynamics-spot." } },
      { "name": "gps_module",       "mass_kg": 0.150, "inertia": [1.5e-4, 1.5e-4, 1.5e-4, 0, 0, 0], "geometry_ref": { "type": "mesh_hash", "hash": "free_humanoid_wheeled_gps_zedf9p_v0" }, "_metadata": { "comment": "Tower-top GPS. Phase 1 spec: u-blox ZED-F9P-02B-01B multi-band RTK GNSS receiver + Ardusimple SimpleRTK2B-Pro carrier + ANN-MB-00 L1/L2 helical antenna. RTCM corrections via NTRIP from a public mountpoint (e.g. UNAVCO / state DOT base) or via the dock-B's RTK base station. ~1 cm CEP after RTK fix. Vendor: u-blox (chip), Ardusimple (carrier). Corpus citation: dlr-justin, pr2 outdoor-variant precedent." } },
      { "name": "imu_base",         "mass_kg": 0.050, "inertia": [1.0e-5, 1.0e-5, 1.0e-5, 0, 0, 0], "geometry_ref": { "type": "mesh_hash", "hash": "free_humanoid_wheeled_imu_vn100_v0" }, "_metadata": { "comment": "Base 9-DoF IMU + dedicated 2-DoF tilt sensor. Phase 1 production spec: VectorNav VN-100 surface-mount industrial AHRS (~$1500). Phase 1 budget alternate: Adafruit BNO055 (~$30) for bench/sim work. Wired direct to safety supervisor (Raspberry Pi 4) for the slope-tilt invariant; also publishes to ROS 2 perception. Corpus citation: roetenberg-xsens-imu (foundational IMU disclosure), dlr-justin (tilt-supervised drive)." } },
      { "name": "modem_5g",         "mass_kg": 0.080, "inertia": [3.0e-5, 3.0e-5, 3.0e-5, 0, 0, 0], "geometry_ref": { "type": "mesh_hash", "hash": "free_humanoid_wheeled_modem_rm502q_v0" }, "_metadata": { "comment": "Cellular modem for fleet coordination. Phase 1 spec: Quectel RM502Q-AE 5G Sub-6 / LTE Cat 20 M.2 modem on a Waveshare USB-to-M.2 carrier with 4-port MIMO antenna kit. Used when WiFi 6 LAN at the dock is unavailable. Vendor: Quectel (modem), Waveshare (carrier). Corpus citation: dlr-justin and the broader mobile-manipulation lineage; cellular modems in robots are commodity." } },
      { "name": "compute_box",      "mass_kg": 1.200, "inertia": [3.0e-3, 3.0e-3, 1.0e-3, 0, 0, 0], "geometry_ref": { "type": "mesh_hash", "hash": "free_humanoid_wheeled_compute_v0" }, "_metadata": { "comment": "On-platform compute. Phase 1 spec: NVIDIA Jetson Orin Nano Super 8GB Developer Kit (67 TOPS, perception + planning, ROS 2) + Raspberry Pi 4 Model B 8GB (safety supervisor on a separate compute domain per Simplex pattern). Mounted inside the chassis. Corpus citation: nvidia-isaac-gym-2021, nvidia-isaac-lab-2024, sherman-simplex-architecture (compute domain separation), levine-gps-pr2-2016 (PR2-class compute heritage)." } },

