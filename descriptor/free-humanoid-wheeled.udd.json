      { "name": "chassis",          "mass_kg": 8.000, "inertia": [3.5e-1, 5.0e-1, 4.0e-1, 0, 0, 0], "geometry_ref": { "type": "mesh_hash", "hash": "free_humanoid_wheeled_chassis_v0" }, "_metadata": { "comment": "Wheeled base chassis. 600x800x350 mm 6061-T6 aluminum monocoque + 3D-printed PA12 covers. Houses battery pack(s), Jetson Orin Nano (perception/planning), Raspberry Pi 4 (safety supervisor), Moteus n1 drive controllers, 5G modem, network switch, drive-bus power conditioning, status indicators. Vendor: McMaster 6061-T6 aluminum stock (8975K426 series); Hubs MJF PA12 print run for covers. Corpus citation: dlr-justin (2009), pr2 (2010)." } },
      { "name": "L_drive_wheel",    "mass_kg": 3.500, "inertia": [3.0e-2, 5.0e-2, 3.0e-2, 0, 0, 0], "geometry_ref": { "type": "mesh_hash", "hash": "catalog_wheel_pneumatic_15in_v0" }, "_metadata": { "comment": "15-inch pneumatic drive wheel, left. Phase 1 spec: ServoCity heavy-duty 15-inch pneumatic wheel (ServoCity 3801-0001-0015-class) on a 12 mm bore hub adapter. Pneumatic for 50 mm curb tolerance (corpus: dlr-justin, pr2 outdoor variants). Vendor: ServoCity (or McMaster 2374K11 equivalent)." } },
